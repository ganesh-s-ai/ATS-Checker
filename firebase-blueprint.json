{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "description": "User profile information and subscription status",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "subscriptionPlan": { "type": "string", "enum": ["free", "pro", "premium"] },
        "credits": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "subscriptionPlan", "createdAt"]
    },
    "ResumeAnalysis": {
      "title": "ResumeAnalysis",
      "description": "A resume analysis report",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "fileName": { "type": "string" },
        "jobDescription": { "type": "string" },
        "score": { "type": "number" },
        "analysis": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "fileName", "score", "analysis", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/UserProfile" },
      "description": "Stores user profiles"
    },
    "/resumes/{resumeId}": {
      "schema": { "$ref": "#/entities/ResumeAnalysis" },
      "description": "Stores resume analysis reports"
    }
  }
}
